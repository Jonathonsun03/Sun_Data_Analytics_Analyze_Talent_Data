library(httr)
library(jsonlite)
library(here)
library(tidyverse)

source(here("scripts", "lib", "utils", "datalake_root.r"))
source(here("scripts", "lib", "Local_LLMs", "ollama_generate.r"))

datalake_root <- get_datalake_root()

paths <- list.files(here(datalake_root,"Leia Memoria【Variance Project】","text_playback"), full.names = TRUE)
file <- read.csv(paths[1])

snippet <- file %>%
  dplyr::filter(!is.na(text), text != "") %>%
  dplyr::slice_head(n = 10) %>%
  dplyr::mutate(line = paste0("[", timecode, "] ", speaker, ": ", text)) %>%
  dplyr::pull(line) %>%
  paste(collapse = "\n")

# Load prompt template from .md
prompt_template <- readLines(
  here("classification", "prompts", "live_chat_logs", "chat_log_summarization.md"),
  warn = FALSE
) %>% paste(collapse = "\n")

# Replace placeholders used in the template
streamer_name <- "Leia Memoria"
prompt_text <- prompt_template %>%
  gsub("\\{STREAMER_NAME\\}", streamer_name, ., perl = TRUE) %>%
  gsub("\\{formatted_snippet\\}", snippet, ., perl = TRUE)

text_out <- ollama_generate(
  prompt = prompt_text,
  model = "gemma:7b",
  host  = "http://100.126.162.100:11434",
  temperature = 0.1
)

cat(text_out)
