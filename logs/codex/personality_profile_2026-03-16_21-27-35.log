+    "theatrical": {"performative hype and bits"},
+    "reassurance": {"warm reassurance"},
+    "vulnerability": set(),
+}
+
+
+@dataclass
+class EvidenceRow:
+    talent: str
+    code_label: str
+    theme_family: str
+    video_id: str
