+    contrast = sorted(others, key=lambda other: abs(target["rates"].get("guidance", 0.0) - other["rates"].get("guidance", 0.0)) + abs(target["rates"].get("reassurance", 0.0) - other["rates"].get("reassurance", 0.0)), reverse=True)[0]
+    shared_signal = max(
