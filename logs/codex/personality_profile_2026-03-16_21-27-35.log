+            with csv_path.open("r", encoding="utf-8-sig", newline="") as handle:
+                reader = csv.DictReader(handle)
+                for row in reader:
+                    video_id = (row.get("Video ID") or row.get("video") or row.get("VideoId") or "").strip()
+                    if video_id not in pending:
