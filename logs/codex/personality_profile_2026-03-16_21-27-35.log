+    month_keys = [dimension.key for dimension in month_dimensions]
+    strengthened = [SIGNAL_LABELS[key] for key in month_keys if month_scores.get(key, 0) >= max(3, round(overall_scores.get(key, 0) * 1.25))]
+    muted = [SIGNAL_LABELS[key] for key in overall_keys if overall_scores.get(key, 0) >= 4 and month_scores.get(key, 0) <= max(1, round(overall_scores.get(key, 0) * 0.65))]
+    lines.append(f"This month {shift}.")
+    if strengthened:
