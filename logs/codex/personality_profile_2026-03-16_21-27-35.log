+    marker_pairs = markers_from_dimensions(overall_dimensions) or [("insufficient evidence", "No marker pattern rose above the general dimensions strongly enough to isolate here.")]
+    lines.extend(f"- {marker}: {note}" for marker, note in marker_pairs)
+    lines.extend(
