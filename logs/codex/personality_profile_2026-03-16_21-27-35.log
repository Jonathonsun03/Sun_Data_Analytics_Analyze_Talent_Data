+            month = parse_date_to_month(summary_path.name)
+            if month:
+                mapping[video_id] = month
+                break
+            text = summary_path.read_text(encoding="utf-8")
+            month = parse_date_to_month(text[:2500])
+            if month:
+                mapping[video_id] = month
