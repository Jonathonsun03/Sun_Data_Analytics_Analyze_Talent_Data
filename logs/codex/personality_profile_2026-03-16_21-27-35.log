def format_dimension_block(dimension: Dimension) -> str:
    quotes = "\n".join(f"- {render_quote(row)}" for row in dimension.quotes)
    return "\n".join(
        [
            f"### {dimension.name}",
            f"- `dimension_name`: {dimension.name}",
            f"- `why this mattered this month`: {dimension.why}" if False else "",
        ]
    )

