+def talent_tokens(talent_name: str) -> List[str]:
+    base = re.sub(r"[【\[].*?[】\]]", " ", talent_name)
+    base = re.sub(r"[^A-Za-z0-9 ]+", " ", base)
+    tokens = [normalize_token(part) for part in base.split() if part.strip()]
