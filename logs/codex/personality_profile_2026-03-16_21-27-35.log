+
+
+def parse_summary_context(md_path: Path, state_path: Optional[Path]) -> dict:
+    text = read_text(md_path)
+    info = {
+        "used": True,
+        "retained_codes": [],
+        "relationship_descriptors": [],
+        "reciprocity": {},
