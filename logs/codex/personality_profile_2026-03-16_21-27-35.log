+def parse_date_to_month(text: str) -> Optional[str]:
+    if not text:
+        return None
+    match = YMD_RE.search(text)
+    if match:
+        year, month, _ = match.groups()
+        return f"{year}-{month}"
+    match = MDY_RE.search(text)
+    if match:
+        month, _, year = match.groups()
