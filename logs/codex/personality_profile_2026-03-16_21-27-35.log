+            month_dir.mkdir(parents=True, exist_ok=True)
+            markdown_path.write_text(markdown, encoding="utf-8")
+            log_rows = log_rows_for_dimensions(talent_name, month, report["dimensions"])
+            monthly_log_total += len(log_rows)
