+VIDEO_ID_RE = re.compile(r"([A-Za-z0-9_-]{11})")
+YMD_RE = re.compile(r"(20\d{2})[-_ ](0[1-9]|1[0-2])[-_ ]([0-3]\d)")
+MDY_RE = re.compile(r"\b(0?[1-9]|1[0-2])[-_ /](0?[1-9]|[12]\d|3[01])[-_ /](20\d{2})\b")
