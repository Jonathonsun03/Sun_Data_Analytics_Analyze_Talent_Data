+def collect_streamer_rows(rows: Sequence[EvidenceRow], talent_name: str) -> List[EvidenceRow]:
+    return [
+        row
+        for row in rows
+        if row.quote
+        and row.video_id
+        and is_streamer_speaker(talent_name, row.speaker)
+    ]
+
