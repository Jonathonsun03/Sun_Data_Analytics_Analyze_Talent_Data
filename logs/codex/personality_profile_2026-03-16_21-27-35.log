+#!/usr/bin/env python3
+"""Build monthly and overall personality synthesis reports from open-coding outputs."""
+
+from __future__ import annotations
+
+import csv
+import json
+import math
+import os
+import re
+from collections import Counter, defaultdict
+from dataclasses import dataclass, field
