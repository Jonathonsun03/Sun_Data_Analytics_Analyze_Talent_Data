+    diff_signal = max(
+        SIGNAL_ORDER,
+        key=lambda signal: abs(target["rates"].get(signal, 0.0) - similar["rates"].get(signal, 0.0)),
+    )
+    paragraph = (
+        f"Shared ground with {similar['name']} and {contrast['name']} appears in the recurring emphasis on {SIGNAL_LABELS[shared_signal]}. "
+        f"What keeps {talent_name} from collapsing into the same profile is the stronger tilt toward {SIGNAL_LABELS[diff_signal]} plus the pacing/reciprocity pattern surfaced in summary classification."
