+            month_rows = [row for row in usable_rows if row.year_month == month]
+            month_dimensions = build_dimensions(month_rows, summary_context, min_rows=2, month_scope=True)
+            if len(month_rows) < 6 or len(month_dimensions) < 2:
+                continue
