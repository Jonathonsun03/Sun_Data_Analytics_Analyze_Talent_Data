+    return max(counts.items(), key=lambda item: item[1])[0]
+
+
+def choose_open_coding_source(talent_dir: Path) -> Optional[dict]:
+    v3 = talent_dir / "stream_summaries/overall_themes/personality_open_coding/v3/current"
