+
+
+def rates_for_rows(rows: Sequence[EvidenceRow]) -> Dict[str, float]:
+    base = max(1, len(rows))
+    return {signal: len(signal_rows(rows, signal)) / base for signal in SIGNAL_ORDER}
+
+
+def run() -> int:
+    profile_summaries: Dict[str, dict] = {}
+    talent_runs: List[dict] = []
