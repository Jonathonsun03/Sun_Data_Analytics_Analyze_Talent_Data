/bin/bash -lc "python3 - <<'PY'
from pathlib import Path
import csv, json
root = Path('/mnt/datalake/DataLake/Sun_Data_Analytics/Talent_data')
results = []
for talent_dir in sorted(p for p in root.iterdir() if p.is_dir() and p.name "'!= '"'VarianceProject'):
    source = talent_dir / 'stream_summaries/overall_themes/personality_open_coding/v3/current/open_coding_evidence_v3.csv'
    codebook = talent_dir / 'stream_summaries/overall_themes/personality_open_coding/v3/current/open_codebook_v3.csv'
    monthly_root = talent_dir / 'stream_summaries/overall_themes/personality_profile/monthly'
    overall_csv = talent_dir / 'stream_summaries/overall_themes/personality_profile/overall/personality_overall_evidence_log_codex.csv'
    summary_md = talent_dir / 'stream_summaries/overall_themes/summary_classification/current/overall_themes_codex.md'
    monthly_logs = sorted(monthly_root.glob('*/personality_monthly_evidence_log_codex.csv'))
    monthly_rows_used = 0
    for path in monthly_logs:
        with path.open('r', encoding='utf-8', newline='') as f:
            monthly_rows_used += sum(1 for _ in csv.DictReader(f))
    with codebook.open('r', encoding='utf-8-sig', newline='') as f:
        retained_codes = sum(1 for _ in csv.DictReader(f))
    with overall_csv.open('r', encoding='utf-8', newline='') as f:
        overall_rows = list(csv.DictReader(f))
    source_index = set()
    with source.open('r', encoding='utf-8-sig', newline='') as f:
        for row in csv.DictReader(f):
            source_index.add(((row.get('video_id') or '').strip(), (row.get('timecode') or '').strip(), (row.get('speaker') or '').strip(), (row.get('quote') or '').strip()))
    checks = []
    for row in overall_rows:
        if row['evidence_role'] not in {'supporting_quote', 'marker_quote', 'money_moment'}:
            continue
        key = (row['video_id'].strip(), row['timecode'].strip(), row['speaker'].strip(), row['quote'].strip())
        if key in source_index:
            checks.append({
                'timecode': row['timecode'],
                'video_id': row['video_id'],
                'speaker': row['speaker'],
                'quote': row['quote'],
                'evidence_role': row['evidence_role'],
            })
        if len(checks) == 2:
            break
    results.append({
        'talent': talent_dir.name,
        'open_coding_source': 'v3 current',
        'resolved_monthly_windows_written': len(monthly_logs),
        'retained_codes_available': retained_codes,
        'monthly_evidence_rows_used': monthly_rows_used,
        'overall_evidence_rows_used': len(overall_rows),
        'summary_classification_used': summary_md.exists(),
        'monthly_root': str(monthly_root),
        'overall_root': str(overall_csv.parent),
        'spot_checks': checks,
    })
print(json.dumps(results, indent=2, ensure_ascii=False))
